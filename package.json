{
	"name": "obsidian-gdrive-encrypted-sync",
	"version": "1.0.0",
	"description": "Obsidian plugin for encrypted Google Drive sync",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"version-bump": "node version-bump.mjs"
	},
	"keywords": [
		"obsidian",
		"google-drive",
		"sync",
		"encryption"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"esbuild": "^0.25.0",
		"obsidian": "latest",
		"typescript": "^5.7.0"
	}
}
